# ── Database ──────────────────────────────────────────────────────────
# Postgres connection string. If you add "Vercel Postgres" (powered by Neon)
# from your Vercel project's Storage tab, it auto-fills this for you.
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Dashboard login ───────────────────────────────────────────────────
# The one admin account for this dashboard.
ADMIN_EMAIL=you@example.com
# A bcrypt hash of your password. Generate one by running:
#   node scripts/hash-password.mjs "yourpassword"
ADMIN_PASSWORD_HASH=

# Long random string used to sign login session cookies. Any long random
# text works, e.g. generate one at https://generate-secret.vercel.app/32
SESSION_SECRET=

# ── Retell AI ─────────────────────────────────────────────────────────
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=+14782764222

# A shared secret you invent yourself (any long random string). You'll
# add "?key=THIS_VALUE" to the webhook/function URLs you give Retell,
# so this app can verify the requests really come from Retell.
RETELL_FUNCTION_SECRET=

# ── Twilio (reference only — Retell places calls through its own SIP
#    trunk connection to Twilio; this app doesn't call Twilio's API
#    directly, these are just kept for your records) ──────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+14782764222

# ── Apollo (optional, reserved — this dashboard doesn't call Apollo
#    directly yet; keep using Apollo exports/CSV to add contacts for now) ─
APOLLO_API_KEY=
